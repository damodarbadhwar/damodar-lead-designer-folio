---
/**
 * Case study — Flipkart UPI.
 * Pixel-perfect implementation of the Figma desktop (54317:4089).
 *
 * Layout follows the same container model as Smart Start Banking:
 *   - Outer container: max-w-[1280px] centered (no widening — this case study
 *     keeps a single column rhythm; full-width images fill the 1160px content
 *     width within px-[60px] gutters).
 *   - Mobile gutter: 16px (px-4)
 *   - Desktop gutter: 60px (md:px-[60px])
 *   - Two-column body sections: 280px label column + 32px gap + flex-1 content
 *
 * Section spacing rhythm — matches Figma section frame heights:
 *   - Title:                  pb-14 (56px)
 *   - Summary:                pb-14 (56px)
 *   - Hero:                   pb-14 (56px)
 *   - Problem:                pb-10 (40px)
 *   - Current flow image:     pb-10 (40px)
 *   - Biggest reason:         pb-10 (40px)
 *   - Why lower success rate: pb-[72px]
 *   - Opportunities:          pb-[72px]
 *   - Market analysis intro:  pb-2  (8px)  — flows directly into image
 *   - Market analysis image:  pb-[72px]
 *   - Competitive analysis:   pb-10 (40px)
 *   - Comp analysis images:   pb-[72px]
 *   - Core user title:        pb-10 (40px)
 *   - Persona container:      pb-[72px]
 *   - Ideation workshop:      pb-10 (40px)
 *   - Themes discussed:       pb-10 (40px)
 *   - Raw ideas:              pb-10 (40px)
 *   - Most voted ideas:       pb-[72px]
 *   - Mood board:             pb-10 (40px)
 *   - Design elements:        pb-10 (40px)
 *   - Exp UI:                 pb-10 (40px)
 *   - Exp success:            pb-[72px]
 *   - Leadership reaction:    pb-[72px]
 *   - Touchpoints:            pb-[72px]
 *   - Link and pay:           pb-[72px]
 *   - NPCI guidelines:        pb-[72px]
 *   - Linking the bank:       pb-[72px]
 *   - Next step UPI:          pb-[72px]
 *   - Success definition:     pb-[72px]
 *   - Result metrics:         pb-[72px]
 *   - Closing thoughts:       pb-[72px]
 *   - Appendix:               pb-[72px]
 *   - End of project banner:  py-10 (40px)
 *   - Next read:              py-[72px]
 */
import BaseLayout from "../../layouts/BaseLayout.astro";
import Nav from "../../components/Nav.astro";
import FadeIn from "../../components/FadeIn.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import TextBlock from "../../components/TextBlock.astro";
import MetaData from "../../components/MetaData.astro";
import NumberedItem from "../../components/NumberedItem.astro";

// — Page meta —
const summary = [
  { label: "ROLE", value: "Lead designer" },
  { label: "TIMELINE", value: "Dec 23 – Apr 24" },
  { label: "PLATFORM", value: "iOS, Android and web" },
];

// — Opportunities (numbered list)
const opportunities = [
  "Every 1% of improvement in success rate would bring in additional ~38 Cr in Gross Revenue.",
  "Improve monthly active users",
];

// — Persona (Manoj Rajan)
const personaCards = [
  {
    label: "Needs",
    items: [
      "Easy discovery of offers and cashback",
      "Clear rewards and savings visibility",
      "Fast, simple UPI payments",
      "Trust before trying new products",
      "Simple reward tracking",
    ],
  },
  {
    label: "Motivations",
    items: [
      "Maximize savings on daily spends",
      "Find exclusive deals early",
      "Get more value from UPI",
      "Share deals with peers",
      "Try tools with clear benefits",
    ],
  },
];

// — Ideation workshop themes
const workshopThemes = [
  {
    label: "Acquisition",
    body: "Why would the user start using Flipkart UPI?",
