          </div>
          <div class="md:flex-1">
            <div class="overflow-hidden rounded-2xl">
              <img
                src="/case-studies/flipkart-upi/raw-ideas.jpg"
                alt="Raw ideas from the workshop"
                class="w-full h-auto object-cover"
                loading="lazy"
              />
            </div>
          </div>
        </div>
      </section>
    </FadeIn>

    <!-- ─────────── Most voted ideas (Figma 54327:29926 — pb 72) ─────────── -->
    <FadeIn>
      <section class="px-4 pb-[72px] md:px-[60px]">
        <div class="flex flex-col gap-3 md:flex-row md:gap-8 md:items-start">
          <div class="md:w-[280px] md:shrink-0">
            <p class="font-serif text-ink-3 text-[20px] leading-[1.4]">
              Most voted ideas
            </p>
          </div>
          <div class="md:flex-1 grid grid-cols-1 md:grid-cols-3 gap-8">
            {votedIdeas.map((idea) => (
              <div class="flex flex-col items-center gap-4">
                <div class="overflow-hidden rounded-2xl bg-grey-200 w-full aspect-[261/160]">
                  <img
                    src={idea.img}
                    alt={idea.caption}
                    class="h-full w-full object-cover"
                    loading="lazy"
                  />
