---
/**
 * Home page hero — gradient backdrop, hero image, name, sub, and contact meta.
 *
 * Image paths point to /public/. Drop these in:
 *   /public/hero-image.jpg     (or .webp) — desktop 812x480, mobile 343x200
 *   /public/gradient-bg.png    (optional — CSS fallback below if missing)
 */
---

<header class="relative overflow-hidden">
  <!--
    Gradient backdrop.
    CSS fallback approximates Figma's soft pastel gradient.
    Drop /public/gradient-bg.png to swap in the exact Figma export.
  -->
  <div
    aria-hidden="true"
    class="absolute inset-0 -z-10 pointer-events-none"
    style="
      background:
        radial-gradient(circle at 18% 12%, rgba(213, 251, 255, 0.85), transparent 55%),
        radial-gradient(circle at 82% 22%, rgba(255, 222, 214, 0.55), transparent 60%),
        radial-gradient(circle at 50% 70%, rgba(255, 240, 200, 0.45), transparent 65%),
        #ffffff;
    "
  ></div>

  <!-- Bottom fade to white so the gradient blends seamlessly into the projects section -->
  <div
    aria-hidden="true"
    class="absolute inset-x-0 bottom-0 -z-10 h-40 pointer-events-none"
    style="background: linear-gradient(to bottom, rgba(255,255,255,0), #ffffff 95%);"
  ></div>

  <div class="mx-auto flex max-w-[1540px] flex-col items-center gap-10 px-5 pb-12 pt-6 md:gap-14 md:px-[150px] md:pb-12 md:pt-6">
    <!-- Pill nav lives here so it scrolls with the header -->
    <slot name="nav" />

    <!-- Hero image -->
    <div
      class="aspect-[812/480] w-full max-w-[812px] overflow-hidden rounded-xl bg-grey-200 md:rounded-3xl"
    >
      <img
        src="/hero-image.jpg"
        alt="Damodar with LINE FRIENDS PLAY characters"
        loading="eager"
        decoding="async"
        class="h-full w-full object-cover"
      />
    </div>

    <!-- Hero text -->
    <div class="flex w-full flex-col items-start gap-3 md:items-center md:gap-4 md:text-center">
      <h1
        class="font-serif font-medium text-display-hero text-ink-3 tracking-[-0.64px] md:w-full md:text-[56px] md:leading-[1.2] md:tracking-[-1.12px]"
      >
        Hi, I'm Damodar
      </h1>
      <p class="text-body text-ink-2 md:w-full">
        Leading design for customer acquisition and growth at Wells Fargo.
      </p>

      <!-- Meta data row -->
      <ul
        class="mt-2 flex w-full flex-col gap-3 md:flex-row md:flex-wrap md:items-center md:justify-center md:gap-6"
      >
        <li class="flex items-center gap-2 text-body text-ink-2">
          <!-- Pin icon -->
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M12 21s-7-6.5-7-12a7 7 0 1 1 14 0c0 5.5-7 12-7 12z M12 11a2 2 0 1 0 0-4 2 2 0 0 0 0 4z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          Bangalore, India
        </li>
        <li class="flex items-center gap-2 text-body text-ink-2">
          <!-- Mail icon -->
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2" stroke="currentColor" stroke-width="1.6"/>
            <path d="m3 7 9 6 9-6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <a href="mailto:damodarbadhwar@gmail.com" class="hover:underline">
            damodarbadhwar@gmail.com
          </a>
        </li>
        <li class="flex items-center gap-2 text-body text-ink-2">
          <!-- Phone icon -->
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
          <a href="tel:+919870526099" class="hover:underline">+91 987 052 6099</a>
        </li>
      </ul>
    </div>
  </div>
</header>
