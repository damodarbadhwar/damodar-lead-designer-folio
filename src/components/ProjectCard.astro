---
/**
 * Case-study card — image, title, blurb, "View case-study" button, showcase tags.
 * Used in the home page "Proud projects" grid.
 */
export interface Props {
  href: string;
  image: string;
  imageAlt: string;
  title: string;
  blurb: string;
  showcases: string[];
}

const { href, image, imageAlt, title, blurb, showcases } = Astro.props;
---

<article class="group flex min-w-0 flex-1 flex-col gap-5">
  <!-- Image — clicking takes user to case study -->
  <a
    href={href}
    class="block aspect-[612/356] w-full overflow-hidden rounded-xl bg-grey-200 md:rounded-2xl"
    aria-label={`Open case study — ${title}`}
  >
    <img
      src={image}
      alt={imageAlt}
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover"
    />
  </a>

  <div class="flex flex-col gap-4">
    <div class="flex flex-col gap-2 text-ink-2">
      <h3 class="text-h5 font-medium">{title}</h3>
      <p class="text-body">{blurb}</p>
    </div>

    <!-- View case-study button -->
    <a
      href={href}
      class="inline-flex w-full items-center justify-center gap-2 rounded-lg bg-ink-1 p-3 text-button font-medium text-white transition-all duration-200 hover:bg-ink-3 hover:-translate-y-0.5 hover:shadow-[0_6px_16px_rgba(0,0,0,0.10)] md:w-auto md:self-start"
    >
      View case-study
    </a>
  </div>

  <!-- Showcase tags -->
  <div class="flex flex-wrap items-center gap-2">
    <span class="text-body text-ink-1">Showcases</span>
    {showcases.map((tag) => (
      <span
        class="inline-flex items-center rounded bg-grey-200 p-1 text-caption font-medium uppercase text-ink-1"
      >
        {tag}
      </span>
    ))}
  </div>
</article>
