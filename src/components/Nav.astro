---
/**
 * Pill navigation matching Figma — Home (active, dark) + Resume (opens PDF).
 * Sticky so it stays accessible as the user scrolls.
 */
export interface Props {
  active?: "home" | "resume";
}
const { active } = Astro.props;
---

<nav class="sticky top-6 z-50 flex justify-center">
  <div
    class="flex items-center gap-2 rounded-full border border-divider bg-white p-[9px] shadow-[0_8px_24px_rgba(0,0,0,0.05),0_2px_6px_rgba(0,0,0,0.04)]"
  >
    <a
      href="/"
      aria-current={active === "home" ? "page" : undefined}
      class:list={[
        "flex items-center gap-1.5 rounded-full px-4 py-2 text-sm transition-colors duration-200",
        active === "home"
          ? "bg-ink-2 text-white"
          : "text-ink-2 hover:bg-grey-200",
      ]}
    >
      <!-- Home icon -->
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M3 12L12 3l9 9M5 10v10h14V10" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Home
    </a>
    <a
      href="/Resume-Damodar-Lead-Product-Designer-2026.pdf"
      target="_blank"
      rel="noopener"
      aria-label="Open resume PDF in new tab"
      class:list={[
        "flex items-center gap-1.5 rounded-full px-4 py-2 text-sm transition-colors duration-200",
        active === "resume"
          ? "bg-ink-2 text-white"
          : "text-ink-2 hover:bg-grey-200",
      ]}
    >
      <!-- Document icon -->
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" aria-hidden="true">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z M14 2v6h6 M16 13H8 M16 17H8 M10 9H8" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Resume
    </a>
  </div>
</nav>
