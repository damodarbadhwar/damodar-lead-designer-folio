---
/**
 * Horizontal article card — image left, content right.
 * Used in "Writings" and "Community" sections.
 *
 * On mobile, stacks vertically (image on top).
 */
export interface Props {
  href: string;
  image: string;
  imageAlt: string;
  title: string;
  blurb: string;
  cta: string;
}

const { href, image, imageAlt, title, blurb, cta } = Astro.props;
---

<a
  href={href}
  target="_blank"
  rel="noopener"
  class="group flex w-full flex-col items-stretch gap-4 overflow-hidden rounded-xl border border-divider bg-surface-2 transition-all duration-300 hover:-translate-y-0.5 hover:shadow-[0_10px_24px_rgba(0,0,0,0.06)] md:flex-row md:items-center md:gap-4 md:py-3"
>
  <!-- Image -->
  <div
    class="aspect-[300/187] w-full shrink-0 overflow-hidden bg-grey-200 md:aspect-auto md:h-[169px] md:w-[300px]"
  >
    <img
      src={image}
      alt={imageAlt}
      loading="lazy"
      decoding="async"
      class="h-full w-full object-cover transition-transform duration-500 group-hover:scale-[1.03]"
    />
  </div>

  <!-- Text -->
  <div class="flex min-w-0 flex-1 flex-col gap-4 px-6 pb-6 md:py-0">
    <h3 class="text-body font-semibold text-ink-2">{title}</h3>
    <p class="text-body text-ink-2">{blurb}</p>
    <div class="pt-4">
      <span
        class="inline-flex items-center gap-2 rounded-lg border border-ink-1 bg-surface-1 px-3 py-2.5 text-button font-medium text-ink-1"
      >
        {cta}
        <!-- Arrow up-right icon -->
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <path d="M6 14 14 6 M7 6h7v7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </span>
    </div>
  </div>
</a>
